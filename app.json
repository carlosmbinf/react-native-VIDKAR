{
  "expo": {
    "name": "Vidkar",
    "slug": "vidkar",
    "version": "4.0.875",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#09111f",
      "dark": {
        "image": "./assets/images/splash-transparent.png",
        "backgroundColor": "#09111f"
      }
    },
    "scheme": "vidkar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "buildNumber": "872",
      "bundleIdentifier": "com.vidkar",
      "appleTeamId": "4TWB6RN383",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Vidkar",
        "CFBundleName": "Vidkar",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "location"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "www.vidkar.com": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD1r5uJ1PBgUaZkqKtlCgInLJtrA-Fem5g"
        }
      },
      "versionCode": 872,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vidkar",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "name": "Vidkar",
      "shortName": "Vidkar",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@bacons/apple-targets",
      "./plugins/with-vidkar-google-maps-key.js",
      "./node_modules/@react-native-google-signin/google-signin/app.plugin.js",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "VIDKAR necesita acceso a la cámara para capturar evidencias de pago.",
          "photosPermission": "VIDKAR necesita acceso a tus fotos para seleccionar evidencias de pago."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "VIDKAR necesita acceso permanente a tu ubicación para compartir la posición del cadete y coordinar entregas incluso cuando la app esté en segundo plano.",
          "locationAlwaysPermission": "VIDKAR necesita acceso permanente a tu ubicación para mantener activo el seguimiento del cadete durante las entregas.",
          "locationWhenInUsePermission": "VIDKAR necesita acceso a tu ubicación para seleccionar puntos de entrega y activar el modo cadete.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09111f",
          "image": "./assets/images/icon.png",
          "imageWidth": 4,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#09111f"
          }
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "meteorUrl": "ws://www.vidkar.com:3000/websocket",
      "eas": {
        "projectId": "8e109c94-83e2-410e-ab33-a31cd79c543c",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "VidkarWatch",
                  "bundleIdentifier": "com.vidkar.watchkitapp"
                }
              ]
            }
          }
        }
      }
    },
    "owner": "carlosmbinf"
  }
}
